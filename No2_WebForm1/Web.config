<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <!--
      Replace the placeholders below with your actual SQL Server details:
        Server   : your SQL Server instance name (e.g. localhost\SQLEXPRESS)
        Database : your database name (e.g. MyAppDB)
        User Id  : SQL login username
        Password : SQL login password

      For Windows Authentication, replace "User Id=...;Password=...;"
      with "Integrated Security=True;"
    --> 13
    <add name="DefaultConnection"
        connectionString="Server=YOUR_SERVER; Database=YOUR_DATABASE; User Id=YOUR_USERNAME;Password=YOUR_PASSWORD;"
        providerName="System.Data.SqlClient" />
  </connectionStrings>

  <system.web>
     <compilation debug="true" targetFramework="4.8" />
     <httpRuntime target Framework="4.8" />
  </system.web>
</configuration>
